<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <!-- PostgreSQL connection -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/cp_portal</property>
        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">postgres</property>

        <!-- SQL dialect and schema behavior -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Entity mappings -->
        <mapping class="model.User"/>
        <mapping class="model.Problem"/>
        <mapping class="model.TestCase"/>
        <mapping class="model.Submission"/>
        <mapping class="model.SubmissionResult"/>
        <mapping class="model.Contest"/>
        <mapping class="model.ContestProblem"/>
        <mapping class="model.ContestRegistration"/>
        <mapping class="model.Leaderboard"/>
    </session-factory>
</hibernate-configuration>
